generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEDICAL_REP
  DOCTOR
  CLINIC_STAFF
  CHEMIST
  STOCKIST
  PHARMA_COMPANY
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Doctor {
  id                  String         @id @default(cuid())
  name                String
  specialty           String
  qualification      String
  hospital            String
  chamberAddress      String
  latitude            Float?
  longitude           Float?
  consultationTiming  String
  mrVisitingTime      String?
  phone               String
  secretaryContact    String?
  languages           String
  experience          Int
  rating              Float          @default(0)
  status              String         @default("available")
  patientsLeft        Int?
  patientsSource      String?
  statusUpdatedAt     DateTime?
  statusUpdatedById   String?
  statusUpdatedByName String?
  statusUpdatedByRole String?
  visits              Visit[]
  updates             DoctorUpdate[]
  planItems           PlanItem[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

// An MR's ordered visit checklist for one day. "Rearrange planning" = order.
model PlanItem {
  id          String   @id @default(cuid())
  mrId        String
  date        String // plan day, "YYYY-MM-DD" (IST)
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId    String
  order       Int      @default(0)
  plannedTime String? // e.g. "4:30 PM"
  status      String   @default("planned") // planned | done | skipped
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mrId, date, doctorId])
  @@index([mrId, date])
}

// Audit trail: every status / patient-count edit, linked to a real account.
model DoctorUpdate {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  userId    String?
  userName  String?
  userEmail String?
  role      String?
  changes   Json
  createdAt DateTime @default(now())

  @@index([doctorId])
}

model Visit {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  date      String // calendar day of the call, "YYYY-MM-DD"
  time      String // e.g. "4:30 PM"
  status    String   @default("Visit Done")
  notes     String?
  mrId      String?
  mrName    String?
  mrEmail   String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([doctorId])
}
