generator client {
  provider = "prisma-client-js"
  // native/windows: Sam's machine · debian: the Claude bridge VM ·
  // rhel: Vercel's serverless runtime (Amazon Linux) — without it the deployed
  // app throws "could not locate Query Engine" at first query.
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEDICAL_REP
  DOCTOR
  CLINIC_STAFF
  CHEMIST
  STOCKIST
  PHARMA_COMPANY
  ADMIN
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
  role     Role
  // Module 4 · trust attribution. For an MR this is their pharma company
  // ("Sun Pharma"). It is deliberately PUBLIC: when an MR confirms a doctor's
  // status the directory shows "confirmed by Ramesh, Sun Pharma", which is the
  // accountability mechanism — a name with a company behind it is answerable.
  // Phone and every other MR field stay private (see MR profile spec).
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Doctor {
  id                  String         @id @default(cuid())
  // Module 4: the doctor's own login account (User with role DOCTOR).
  // Set once via the claim flow — lets the doctor edit their OWN profile only.
  userId              String?        @unique
  name                String
  specialty           String
  qualification      String
  hospital            String
  chamberAddress      String
  latitude            Float?
  longitude           Float?
  consultationTiming  String
  mrVisitingTime      String?
  mrVisitingDays      String? // e.g. "Mon, Wed, Fri"
  phone               String
  secretaryContact    String?
  languages           String
  experience          Int
  rating              Float          @default(0)
  status              String         @default("available")
  patientsLeft        Int?
  patientsSource      String?
  statusUpdatedAt     DateTime?
  statusUpdatedById   String?
  statusUpdatedByName String?
  statusUpdatedByRole String?
  // Denormalized at write time (same pattern as Visit/DoctorUpdate) so the
  // attribution stays readable even if the MR later changes company or leaves.
  statusUpdatedByCompany String?
  // Module 4: recurring baseline hours, edited by the doctor only.
  // JSON object keyed by day: { "mon": "10 AM – 1 PM, 6 – 9 PM", ... }
  weeklyTimetable     Json?
  // Module 6: MR-sourced data entry. Every new profile records WHO added it
  // (trust attribution) and starts unverified unless an admin created it.
  // Unverified profiles are visible only to their creator + admins.
  addedById           String?
  addedByName         String?
  addedByRole         String?
  verified            Boolean        @default(true)
  visits              Visit[]
  updates             DoctorUpdate[]
  planItems           PlanItem[]
  mrDoctors           MrDoctor[]
  dayPlans            DoctorDayPlan[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([verified])
}

// ─── Module 4 · Doctor's own shared day plan ────────────────────────────────
// The doctor starts their day and shares a day-wise plan / to-do list
// (e.g. "10–1 OPD", "2–4 hospital rounds", "6–9 evening chamber").
// Patients and MRs see it on the public directory, plan around it, and
// cross-check the live status against it. Visibility = more patients,
// which is what encourages the doctor to keep sharing.
model DoctorDayPlan {
  id        String    @id @default(cuid())
  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  date      String // plan day, "YYYY-MM-DD" (IST)
  items     Json      @default("[]") // [{ id, time, activity, done }]
  shared    Boolean   @default(true) // doctor can keep a day private
  startedAt DateTime? // set when the doctor taps "Start My Day"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([doctorId, date])
  @@index([date])
}

// An MR's ordered visit checklist for one day. "Rearrange planning" = order.
model PlanItem {
  id          String   @id @default(cuid())
  mrId        String
  date        String // plan day, "YYYY-MM-DD" (IST)
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId    String
  order       Int      @default(0)
  plannedTime String? // e.g. "4:30 PM"
  status      String   @default("planned") // planned | done | skipped
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mrId, date, doctorId])
  @@index([mrId, date])
}

// ─── Phase 3 · MR Tools ──────────────────────────────────────────────────────

// A doctor on an MR's personal working list (their company-assigned universe).
// frequency = how many times per month the company expects this doctor visited
// (e.g. core doctors 3×, others 2×). Sum of frequencies = monthly call target.
model MrDoctor {
  id        String   @id @default(cuid())
  mrId      String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  frequency Int      @default(2) // planned visits per month (1–4)
  patch     Patch?   @relation(fields: [patchId], references: [id], onDelete: SetNull)
  patchId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mrId, doctorId])
  @@index([mrId])
  @@index([patchId])
}

// A call patch = a named group of doctors an MR covers together in one day
// (usually one area/route). Loading a patch fills that day's plan in one tap.
model Patch {
  id        String     @id @default(cuid())
  mrId      String
  name      String // e.g. "Patch A – Salt Lake"
  doctors   MrDoctor[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([mrId, name])
  @@index([mrId])
}

// Audit trail: every status / patient-count edit, linked to a real account.
model DoctorUpdate {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  userId    String?
  userName  String?
  userEmail String?
  role      String?
  changes   Json
  createdAt DateTime @default(now())

  @@index([doctorId])
}

// ─── Module 5 · Call MR ─────────────────────────────────────────────────────
// A doctor (or chemist/stockist later) asks an MR to call them. Lands as a
// notification on that MR's dashboard: who asked, when, and its state.
// Names are denormalized (same pattern as Visit/DoctorUpdate) so the record
// stays readable even if accounts change.
model CallRequest {
  id         String   @id @default(cuid())
  mrId       String // target MR (User.id)
  fromUserId String // requesting account (User.id)
  fromName   String
  fromRole   String
  doctorId   String? // requester's Doctor profile, when linked
  note       String?
  status     String   @default("pending") // pending | seen | done
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([mrId, status])
  @@index([fromUserId])
}

model Visit {
  id        String   @id @default(cuid())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId  String
  date      String // calendar day of the call, "YYYY-MM-DD"
  time      String // e.g. "4:30 PM"
  status    String   @default("Visit Done")
  notes     String?
  mrId      String?
  mrName    String?
  mrEmail   String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([doctorId])
}
